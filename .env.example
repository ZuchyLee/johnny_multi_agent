# ─────────────────────────────────────────
# Telegram Bot 設定
# ─────────────────────────────────────────

# 從 @BotFather 取得的 Bot Token
BOT_TOKEN=1234567890:ABCDefghIJKlmnoPQRstuvwXYZ

# 你的 Telegram 使用者 ID（找 @userinfobot 查詢）
OWNER_ID=123456789

# Telegram 群組的 chat_id（負數）
# 先把 BOT_TOKEN 填好後啟動 bot，在群組裡傳一則訊息，bot 會回覆 chat_id
GROUP_ID=-1001234567890

# ─────────────────────────────────────────
# 路徑設定（通常不需要改）
# ─────────────────────────────────────────

# 各 Topic 工作區的存放位置（預設為專案內的 workspaces/ 資料夾）
# WORKSPACE_ROOT=/path/to/workspaces

# ─────────────────────────────────────────
# AI 模型設定
# ─────────────────────────────────────────

# 一般 Topic 預設使用的模型
DEFAULT_MODEL=claude-opus-4-8

# 主控 Topic（General）使用的模型
MASTER_MODEL=claude-opus-4-8

# Claude CLI 的執行路徑（通常不需要改，預設會自動找）
# CLAUDE_PATH=/usr/local/bin/claude
